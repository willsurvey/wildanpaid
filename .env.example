# =============================================================================
# RADAR BURSA - Environment Variables
# =============================================================================
# Salin file ini menjadi .env dan isi dengan data Anda.
# JANGAN pernah commit file .env ke Git!
# =============================================================================

# --- Stockbit Credentials ---
STOCKBIT_USERNAME=email_atau_username_stockbit_anda
STOCKBIT_PASSWORD=password_stockbit_anda
STOCKBIT_PLAYER_ID=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-100123456789

# --- Telegram Topics (Opsional) ---
# Isi dengan ID Topik (angka) jika fitur Topics diaktifkan di Grup.
# Biarkan kosong jika tidak ingin menggunakan topik.
TELEGRAM_TOPIC_INSTITUTIONAL=
TELEGRAM_TOPIC_WHALE=
TELEGRAM_TOPIC_MOMENTUM=
TELEGRAM_TOPIC_DISTRIBUTION=

# --- Opsional: Override manual ---
# Jika diset, sistem akan menggunakan token ini tanpa login ulang.
# STOCKBIT_BEARER_TOKEN=eyJhbGciOiJSUzI1NiIs...
